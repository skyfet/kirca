{
  "info": {
    "name": "Kirca API E2E",
    "description": "Newman-runnable smoke suite. Run via `npm run test:e2e` (locally or in CI). baseUrl is read from the environment file or overridden via `--env-var baseUrl=...`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Register (fresh user)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now().toString(36) + Math.random().toString(36).slice(2, 6);",
              "pm.environment.set('username', 'e2e_' + suffix);",
              "pm.environment.set('password', 'pw_' + suffix);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('token returned', () => pm.expect(j.token).to.be.a('string').and.to.have.length.above(10));",
              "pm.test('user object matches', () => {",
              "  pm.expect(j.user).to.be.an('object');",
              "  pm.expect(j.user.username).to.eql(pm.environment.get('username'));",
              "  pm.expect(j.user.id).to.be.a('string');",
              "});",
              "pm.environment.set('token', j.token);",
              "pm.environment.set('userId', j.user.id);"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/register",
          "host": ["{{baseUrl}}"],
          "path": ["register"]
        }
      }
    },
    {
      "name": "Register duplicate -> 409",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 409', () => pm.response.to.have.status(409));",
              "pm.test('error message', () => pm.expect(pm.response.json().error).to.match(/taken/i));"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}",
          "options": { "raw": { "language": "json" } }
