{
  "info": {
    "name": "Kirca API E2E",
    "description": "Newman-runnable smoke suite. Run via `npm run test:e2e` (locally or in CI). baseUrl is read from the environment file or overridden via `--env-var baseUrl=...`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Register (fresh user)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now().toString(36) + Math.random().toString(36).slice(2, 6);",
              "pm.environment.set('username', 'e2e_' + suffix);",
              "pm.environment.set('password', 'pw_' + suffix);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('token returned', () => pm.expect(j.token).to.be.a('string').and.to.have.length.above(10));",
              "pm.test('user object matches', () => {",
              "  pm.expect(j.user).to.be.an('object');",
              "  pm.expect(j.user.username).to.eql(pm.environment.get('username'));",
              "  pm.expect(j.user.id).to.be.a('string');",
              "});",
              "pm.environment.set('token', j.token);",
              "pm.environment.set('userId', j.user.id);"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/register",
          "host": ["{{baseUrl}}"],
          "path": ["register"]
        }
      }
    },
    {
      "name": "Register duplicate -> 409",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 409', () => pm.response.to.have.status(409));",
              "pm.test('error message', () => pm.expect(pm.response.json().error).to.match(/taken/i));"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/register",
          "host": ["{{baseUrl}}"],
          "path": ["register"]
        }
      }
    },
    {
      "name": "Login (same creds)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('returns new token', () => pm.expect(j.token).to.be.a('string'));",
              "pm.test('user.id stable', () => pm.expect(j.user.id).to.eql(pm.environment.get('userId')));",
              "pm.environment.set('token', j.token);"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": ["{{baseUrl}}"],
          "path": ["login"]
        }
      }
    },
    {
      "name": "Login wrong password -> 401",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 401', () => pm.response.to.have.status(401));"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"definitely-wrong\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": ["{{baseUrl}}"],
          "path": ["login"]
        }
      }
    },
    {
      "name": "GET /rooms without token -> 401",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 401', () => pm.response.to.have.status(401));"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/rooms",
          "host": ["{{baseUrl}}"],
          "path": ["rooms"]
        }
      }
    },
    {
      "name": "Create Room",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.environment.set('roomName', 'e2e-' + Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('id and name returned', () => {",
              "  pm.expect(j.id).to.be.a('string');",
              "  pm.expect(j.name).to.eql(pm.environment.get('roomName'));",
              "});",
              "pm.environment.set('roomId', j.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{roomName}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/rooms",
          "host": ["{{baseUrl}}"],
          "path": ["rooms"]
        }
      }
    },
    {
      "name": "List Rooms (includes created)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('rooms is array', () => pm.expect(j.rooms).to.be.an('array'));",
              "pm.test('contains created room', () => {",
              "  const ids = j.rooms.map(r => r.id);",
              "  pm.expect(ids).to.include(pm.environment.get('roomId'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/rooms",
          "host": ["{{baseUrl}}"],
          "path": ["rooms"]
        }
      }
    },
    {
      "name": "Get Room History (empty)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('messages is empty array', () => {",
              "  pm.expect(j.messages).to.be.an('array');",
              "  pm.expect(j.messages.length).to.eql(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/rooms/{{roomId}}/history",
          "host": ["{{baseUrl}}"],
          "path": ["rooms", "{{roomId}}", "history"]
        }
      }
    }
  ]
}
